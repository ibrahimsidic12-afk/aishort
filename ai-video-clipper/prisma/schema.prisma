generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Teams ───────────────────────────────────────────────

model User {
  id        String    @id @default(cuid())
  clerkId   String    @unique
  email     String    @unique
  name      String?
  avatarUrl String?
  plan      Plan      @default(FREE)
  credits   Int       @default(10)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  videos        Video[]
  clips         Clip[]
  jobs          Job[]
  subscription  Subscription?
  usageRecords  UsageRecord[]
  teamMembers   TeamMember[]
  youtubeTokens YouTubeToken?
  tiktokTokens  TikTokToken?

  @@map("users")
}

model Team {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members TeamMember[]

  @@map("teams")
}

model TeamMember {
  id     String   @id @default(cuid())
  userId String
  teamId String
  role   TeamRole @default(MEMBER)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("team_members")
}

// ─── Videos & Clips ──────────────────────────────────────────────

model Video {
  id           String      @id @default(cuid())
  userId       String
  title        String
  description  String?
  fileName     String
  fileSize     Int
  duration     Float?
  mimeType     String
  storageKey   String
  storageUrl   String?
  status       VideoStatus @default(UPLOADING)
  metadata     Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transcript Transcript?
  clips      Clip[]
  jobs       Job[]

  @@index([userId])
  @@map("videos")
}

model Clip {
  id            String     @id @default(cuid())
  userId        String
  videoId       String
  title         String
  description   String?
  startTime     Float
  endTime       Float
  duration      Float
  storageKey    String?
  storageUrl    String?
  thumbnailUrl  String?
  status        ClipStatus @default(PENDING)
  score         Float?
  viralityScore Float?
  tags          String[]
  captions      Json?
  metadata      Json?
  publishedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  video        Video         @relation(fields: [videoId], references: [id], onDelete: Cascade)
  publications Publication[]

  @@index([userId])
  @@index([videoId])
  @@map("clips")
}

model Transcript {
  id        String            @id @default(cuid())
  videoId   String            @unique
  content   String
  segments  Json
  language  String?
  provider  TranscriptProvider @default(DEEPGRAM)
  createdAt DateTime          @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@map("transcripts")
}

// ─── Publishing ──────────────────────────────────────────────────

model Publication {
  id         String          @id @default(cuid())
  clipId     String
  platform   Platform
  externalId String?
  url        String?
  status     PublishStatus   @default(PENDING)
  error      String?
  publishedAt DateTime?
  createdAt  DateTime        @default(now())

  clip Clip @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([clipId])
  @@map("publications")
}

model YouTubeToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  channelId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("youtube_tokens")
}

model TikTokToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  openId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tiktok_tokens")
}

// ─── Jobs & Processing ───────────────────────────────────────────

model Job {
  id        String    @id @default(cuid())
  userId    String
  videoId   String?
  type      JobType
  status    JobStatus @default(QUEUED)
  progress  Int       @default(0)
  result    Json?
  error     String?
  startedAt DateTime?
  completedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video? @relation(fields: [videoId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@map("jobs")
}

// ─── Billing ─────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(INACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model UsageRecord {
  id        String    @id @default(cuid())
  userId    String
  type      UsageType
  quantity  Int       @default(1)
  metadata  Json?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("usage_records")
}

// ─── Enums ───────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum VideoStatus {
  UPLOADING
  PROCESSING
  TRANSCRIBING
  READY
  ERROR
}

enum ClipStatus {
  PENDING
  GENERATING
  RENDERING
  READY
  PUBLISHED
  ERROR
}

enum JobType {
  TRANSCRIPTION
  CLIP_GENERATION
  CLIP_RENDERING
  THUMBNAIL_GENERATION
  PUBLISH
  CLEANUP
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum Platform {
  YOUTUBE
  TIKTOK
  INSTAGRAM
}

enum PublishStatus {
  PENDING
  UPLOADING
  PUBLISHED
  FAILED
}

enum TranscriptProvider {
  WHISPER
  DEEPGRAM
  ASSEMBLYAI
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELLED
}

enum UsageType {
  VIDEO_UPLOAD
  TRANSCRIPTION
  CLIP_GENERATION
  CLIP_RENDER
  PUBLISH
}



// ─── Webhook Events (Idempotency) ───────────────────────────────

model WebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String?  @unique
  clerkEventId  String?  @unique
  type          String
  processedAt   DateTime @default(now())

  @@map("webhook_events")
}
